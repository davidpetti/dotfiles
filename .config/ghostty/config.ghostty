# Font
font-family = JetBrainsMono Nerd Font
font-feature = -liga, -calt

# Window
window-save-state = always
background-opacity = 0.9
background-blur-radius = 20
window-padding-x = 10
window-padding-y = 8

# Mouse
mouse-hide-while-typing = true

# TMUX auto-launch on startup
command = /opt/homebrew/bin/tmux new-session -A -s main

# Gruvbox Dark — matches gruvbox.nvim dark with default contrast ("")
background = #282828
foreground = #ebdbb2

cursor-color = #ebdbb2
cursor-text = #282828

selection-background = #504945
selection-foreground = #ebdbb2

palette = 0=#282828
palette = 1=#cc241d
palette = 2=#98971a
palette = 3=#d79921
palette = 4=#458588
palette = 5=#b16286
palette = 6=#689d6a
palette = 7=#a89984
palette = 8=#928374
palette = 9=#fb4934
palette = 10=#b8bb26
palette = 11=#fabd2f
palette = 12=#83a598
palette = 13=#d3869b
palette = 14=#8ec07c
palette = 15=#ebdbb2
